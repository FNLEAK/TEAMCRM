NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Minimum for Supabase CRM pages: NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY only.
# Add the variables below when your database columns / features need them (see comments).

# Two pipeline-style UIs:
# - / and /pipeline-command-center → Supabase session (this URL + keys).
# - /pipeline → same browser app but uses NEXT_PUBLIC_API_URL + JWT (Node API). Behaviors can differ; test both if you use both.

# Supabase (CRM dashboard on home page)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: Role Applier “pending” list (all Auth users). Never expose in the browser.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Production site URL for signup confirmation & magic links (must match Supabase → Authentication → URL Configuration).
# Example: https://your-app.vercel.app — add the same origin + https://.../auth/callback under Redirect URLs.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Partner webhook: POST /api/webhooks/booked-call — Authorization: Bearer <same value>
# Run `supabase/leads-source-booking-webhook.sql` first. Requires SUPABASE_SERVICE_ROLE_KEY.
# WEB_FRIENDLY_WEBHOOK_SECRET=long-random-string-share-only-with-trusted-sender
# Optional: override `leads.status` for webhook rows — must match leads_status_check (see SQL in Supabase).
# Default in code is `Website Booked` (shows under “Website booked calls” in Kanban). If constraint errors until you run
# supabase/leads-status-add-website-booked.sql, temporarily set:
# WEB_FRIENDLY_LEAD_STATUS=New

# --- Security (optional) ---
# Hide "Sign up" on /login — pair with Supabase Auth → disable "Allow new users to sign up" for invite-only.
# NEXT_PUBLIC_DISABLE_PUBLIC_SIGNUP=true
# Restrict new signups to specific email domains (comma-separated, no @).
# NEXT_PUBLIC_SIGNUP_ALLOWED_DOMAINS=yourcompany.com
# Primary owner email for UI + RLS bootstrap (defaults in code if unset). Use lowercase.
# NEXT_PUBLIC_OWNER_EMAIL=you@yourcompany.com

# Package auto-send (API route /api/send-package): Gmail SMTP + App Password (2-Step Verification). Server-only — never NEXT_PUBLIC_*.
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Owner approval gate is ON by default (blocking modal until Role Applier assigns team|owner). Set false to disable.
# NEXT_PUBLIC_REQUIRE_OWNER_APPROVAL=false

# Default: single uuid column (uses .eq). Set to true only if favorited_by is uuid[] / jsonb array.
# NEXT_PUBLIC_LEADS_FAVORITES_AS_ARRAY=true

# After `alter table public.leads add column claimed_by uuid references auth.users (id);` (profiles-and-claimed.sql)
# `claimed_by` is selected by default. Set false only if the column is not migrated yet:
# NEXT_PUBLIC_LEADS_HAS_CLAIMED_BY=false

# `last_activity_by` (squad-streak-lead-activity.sql) — default on for My schedule / sync. Opt out:
# NEXT_PUBLIC_LEADS_HAS_LAST_ACTIVITY_BY=false

# Command Center (/pipeline-command-center): max leads loaded for KPI + Kanban (default 10000, min 500, max 100000).
# NEXT_PUBLIC_COMMAND_CENTER_LEADS_LIMIT=15000

# `appt_scheduled_by` is included in selects by default (needed for “My schedule”).
# Set only if your table does NOT have this column yet:
# NEXT_PUBLIC_LEADS_HAS_APPT_SCHEDULED_BY=false

# Embeds scheduler profiles on each lead (full_name, avatar_initials). Requires FK
# appt_scheduled_by → profiles.id — run `supabase/leads-appt-scheduled-by-profiles-fk.sql`.
# Set to false only if the embed breaks your query (FK still on auth.users only).
# NEXT_PUBLIC_LEADS_SCHEDULER_PROFILE_EMBED=false

# If your FK constraint name differs, set the PostgREST hint (default: leads_appt_scheduled_by_fkey).
# NEXT_PUBLIC_LEADS_SCHEDULER_PROFILE_FK_HINT=leads_appt_scheduled_by_fkey

# Run `supabase/team-calendar-day-notes.sql` for dashboard “Daily briefing” (table: team_calendar_day_notes).
# If you kept the singular table name instead:
# NEXT_PUBLIC_TEAM_DAY_NOTES_TABLE=team_calendar_day_note
# If the calendar-day column is named `date` instead of `day`:
# NEXT_PUBLIC_TEAM_DAY_NOTES_DATE_COLUMN=date

# Optional: fixed calendar colors for Team schedule — up to 5 user UUIDs in order (emerald, blue, violet, amber, rose slots).
# NEXT_PUBLIC_CALENDAR_TEAM_USER_IDS=uuid1,uuid2,uuid3,uuid4,uuid5
